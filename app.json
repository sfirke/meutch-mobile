{
  "expo": {
    "name": "Meutch",
    "slug": "meutch-mobile",
    "scheme": "meutch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_m.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_m.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6ad55"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meutch.app"
    },
    "android": {
      "package": "com.meutch.app",
      "adaptiveIcon": {
        "backgroundColor": "#f6ad55",
        "foregroundImage": "./assets/logo_m.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo_m.png"
    }
  }
}
