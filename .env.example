# EXPO_PUBLIC_API_BASE_URL=

# Local examples:
# Android emulator: http://10.0.2.2:5000/api/v1
# Physical Android device: http://<your-linux-lan-ip>:5000/api/v1
EXPO_PUBLIC_LOCAL_API_BASE_URL=http://10.0.2.2:5000/api/v1
EXPO_PUBLIC_INTEGRATION_API_BASE_URL=https://mobile-int-api.meutch.com/api/v1
EXPO_PUBLIC_PRODUCTION_API_BASE_URL=https://meutch.com/api/v1